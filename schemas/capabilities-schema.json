{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "imported-capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "reference-id": {
            "type": "string",
            "description": "Namespace or category for the shared capabilities (e.g., CCC)"
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reference-id": {
                  "type": "string",
                  "pattern": "^CCC\\.Core\\..+$",
                  "description": "Global/common capability IDs (CP## or F## during migration)"
                },
                "strength": {
                  "type": "integer"
                },
                "remarks": {
                  "type": "string"
                }
              },
              "required": ["reference-id"],
              "additionalProperties": false
            }
          },
          "remarks": {
            "type": "string"
          }
        },
        "required": ["reference-id", "entries"],
        "additionalProperties": false
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CCC\\.\\w+\\..+$",
            "description": "Capability ID (e.g., CCC.ObjStor.CP01; CP## or F## during migration)"
          },
          "title": {
            "type": "string",
            "description": "Short title of the capability"
          },
          "description": {
            "type": "string",
            "description": "Detailed explanation of what the capability enables or enforces"
          },
          "group": {
            "type": "string",
            "description": "Group id this capability belongs to (defined in core/ccc/groups.yaml)"
          }
        },
        "required": ["id", "title", "description", "group"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
