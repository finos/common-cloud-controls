{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCC Threat Catalog",
  "description": "Validates CCC threat catalogs against the Gemara 1.2.0 layer-2 ThreatCatalog shape: a top-level title, metadata, groups, threats, and per-threat imports/capabilities/vectors/actors. Threat-to-external-framework mappings live in standalone MappingDocuments under catalogs/**/mappings/ (see schemas/mappingdocument-schema.json).",
  "type": "object",
  "definitions": {
    "multiEntryMapping": {
      "type": "object",
      "properties": {
        "reference-id": {
          "type": "string",
          "description": "Identifies a mapping-reference entry declared in metadata.mapping-references"
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reference-id": {
                "type": "string",
                "description": "Identifier of the entry being mapped to in the referenced artifact"
              },
              "strength": {
                "type": "integer"
              },
              "remarks": {
                "type": "string"
              }
            },
            "required": ["reference-id"],
            "additionalProperties": false
          }
        },
        "remarks": {
          "type": "string"
        }
      },
      "required": ["reference-id", "entries"],
      "additionalProperties": false
    },
    "capabilityMapping": {
      "type": "object",
      "properties": {
        "reference-id": {
          "type": "string",
          "description": "Capability mapping namespace or mapping-reference id (e.g., CCC, ma-ref-arch-capabilities)"
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "reference-id": {
                "type": "string",
                "pattern": "^CCC(\\.[a-zA-Z0-9]+)?\\.CP\\d+$",
                "description": "Feature/Capability ID"
              },
              "strength": {
                "type": "integer"
              },
              "remarks": {
                "type": "string"
              }
            },
            "required": ["reference-id"],
            "additionalProperties": false
          }
        },
        "remarks": {
          "type": "string"
        }
      },
      "required": ["reference-id", "entries"],
      "additionalProperties": false
    },
    "actor": {
      "type": "object",
      "description": "Gemara entity (human or tool)",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["Human", "Software", "Software Assisted"]
        },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "uri": { "type": "string" },
        "contact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "affiliation": { "type": "string" },
            "email": { "type": "string" },
            "social": { "type": "string" }
          },
          "required": ["name"],
          "additionalProperties": false
        }
      },
      "required": ["id", "name", "type"],
      "additionalProperties": false
    }
  },
  "properties": {
    "title": {
      "type": "string",
      "description": "Gemara 1.2.0: human-readable title of the threat catalog"
    },
    "metadata": {
      "type": "object",
      "description": "Gemara 1.2.0: catalog metadata",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the threat catalog"
        },
        "type": {
          "type": "string",
          "const": "ThreatCatalog"
        },
        "gemara-version": {
          "type": "string",
          "description": "Version of the Gemara specification this artifact conforms to"
        },
        "version": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "description": {
          "type": "string"
        },
        "author": {
          "$ref": "#/definitions/actor"
        },
        "mapping-references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "version": { "type": "string" },
              "description": { "type": "string" },
              "url": {
                "type": "string",
                "pattern": "^(https?|file)://[^\\s]+$"
              }
            },
            "required": ["id", "title", "version"],
            "additionalProperties": false
          }
        },
        "applicability-groups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["id", "title", "description"],
            "additionalProperties": false
          }
        },
        "draft": {
          "type": "boolean"
        }
      },
      "required": ["id", "type", "gemara-version", "description"],
      "additionalProperties": false
    },
    "groups": {
      "type": "array",
      "description": "Gemara 1.2.0: groups that threats may be classified under",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["id", "title", "description"],
        "additionalProperties": false
      }
    },
    "imports": {
      "type": "array",
      "description": "Gemara 1.2.0 #Catalog field: threats imported from another catalog (entries constrained to CCC core threat IDs)",
      "items": {
        "type": "object",
        "properties": {
          "reference-id": {
            "type": "string",
            "description": "The shared threat namespace or category identifier (e.g., CCC)"
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reference-id": {
                  "type": "string",
                  "pattern": "^CCC\\.Core.TH\\d{2,8}$",
                  "description": "Global threat identifiers"
                },
                "strength": {
                  "type": "integer"
                },
                "remarks": {
                  "type": "string"
                }
              },
              "required": ["reference-id"],
              "additionalProperties": false
            }
          },
          "remarks": {
            "type": "string"
          }
        },
        "required": ["reference-id", "entries"],
        "additionalProperties": false
      }
    },
    "threats": {
      "type": "array",
      "description": "List of service-specific or global threats",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^((CCC\\.TH\\d{2,8})|(CCC\\.\\w{1,8}\\.TH\\d{2,8}))$",
            "description": "Threat ID (global or service-specific)"
          },
          "title": {
            "type": "string",
            "description": "Short title of the threat"
          },
          "description": {
            "type": "string",
            "description": "Detailed explanation of the threat"
          },
          "group": {
            "type": "string",
            "description": "Group id this threat belongs to (defined in core/ccc/groups.yaml or this catalog's groups)"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/capabilityMapping"
            }
          },
          "vectors": {
            "type": "array",
            "description": "Gemara 1.2.0: mappings between this threat and one or more vectors",
            "items": {
              "$ref": "#/definitions/multiEntryMapping"
            }
          },
          "actors": {
            "type": "array",
            "description": "Gemara 1.2.0: relevant internal or external threat actors",
            "items": {
              "$ref": "#/definitions/actor"
            }
          }
        },
        "required": ["id", "title", "description", "group"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
