{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "imported-controls": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "reference-id": {
              "type": "string",
              "description": "Reference ID for the shared control set, e.g., 'CCC'"
            },
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "reference-id": {
                    "type": "string",
                    "pattern": "^CCC\\.Core.CN\\d{2,8}$",
                    "description": "ID of a generic control that is designed to be shared by multiple catalogs"
                  },
                  "strength": {
                    "type": "integer"
                  },
                  "remarks": {
                    "type": "string"
                  }
                },
                "required": ["reference-id"],
                "additionalProperties": false
              }
            },
            "remarks": {
              "type": "string"
            }
          },
          "required": ["reference-id", "entries"],
          "additionalProperties": false
        }
      },
      "controls": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^((CCC\\.CN\\d{2,8})|(CCC\\.\\w{1,8}\\.CN\\d{2,8}))$",
              "description": "Full control ID (e.g., CCC.ObjStor.CN01)"
            },
            "group": {
              "type": "string",
              "description": "Group id from core/ccc/groups.yaml (e.g., Encryption, Access, Observability, Data, MachineLearning)"
            },
            "title": {
              "type": "string",
              "description": "Title of the control"
            },
            "objective": {
              "type": "string",
              "description": "Multi-line objective of the control"
            },
            "assessment-requirements": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^((CCC\\.CN\\d{2,8})|(CCC\\.\\w{1,8}\\.CN\\d{2,8}\\.AR\\d{2,8}))$",
                    "description": "Test requirement ID"
                  },
                  "text": {
                    "type": "string",
                    "description": "Detailed description of the requirement"
                  },
                  "applicability": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["tlp-clear", "tlp-green", "tlp-amber", "tlp-red"]
                    }
                  },
                  "recommendation": {
                    "type": "string",
                    "description": "Optional recommendation to satisfy this requirement"
                  }
                },
                "required": ["id", "text", "applicability"],
                "additionalProperties": false
              }
            },
            "threats": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "reference-id": {
                    "type": "string"
                  },
                  "entries": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "reference-id": {
                          "type": "string",
                          "pattern": "^((CCC\\.TH\\d{2,8})|(CCC\\.\\w{1,8}\\.TH\\d{2,8}))$"
                        },
                        "strength": {
                          "type": "integer"
                        },
                        "remarks": {
                          "type": "string"
                        }
                      },
                      "required": ["reference-id"],
                      "additionalProperties": false
                    }
                  },
                  "remarks": {
                    "type": "string"
                  }
                },
                "required": ["reference-id", "entries"],
                "additionalProperties": false
              }
            },
            "guidelines": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "reference-id": {
                    "type": "string"
                  },
                  "entries": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "reference-id": {
                          "type": "string"
                        },
                        "strength": {
                          "type": "integer"
                        },
                        "remarks": {
                          "type": "string"
                        }
                      },
                      "required": ["reference-id"],
                      "additionalProperties": false
                    }
                  },
                  "remarks": {
                    "type": "string"
                  }
                },
                "required": ["reference-id", "entries"],
                "additionalProperties": false
              }
            }
          },
          "required": ["id", "group", "title", "objective", "assessment-requirements"],
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
}
